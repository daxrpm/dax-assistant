# Dax Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Settings use the DAX_ prefix with "__" as the nested delimiter, so a TOML
# value like [security].password_hash maps to DAX_SECURITY__PASSWORD_HASH.

# ── Web auth (single-user login) ───────────────────────────────────────────
# Generate the password hash with:  python -m dax.web.auth <your-password>
# DAX_SECURITY__PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
# Random secret used to sign session cookies (e.g. `openssl rand -hex 32`).
# DAX_SECURITY__SESSION_SECRET=change-me-to-a-long-random-string

# ── LLM providers (official SDKs) ──────────────────────────────────────────
# Anthropic (Claude). Default model: claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI. Default model: gpt-5.5
# OPENAI_API_KEY=sk-...
# Google Gemini (google-genai SDK). Default model: gemini-3.5-flash
# GEMINI_API_KEY=...
# Ollama (local) needs no key — configured by base_url in dax.toml.

# ── Integrations (used by MCP servers via {env:VAR} substitution) ──────────
# NEXTCLOUD_PASSWORD=your-password-here
# HA_TOKEN=your-long-lived-access-token
# SPOTIFY_CLIENT_ID=your-client-id
# SPOTIFY_CLIENT_SECRET=your-client-secret

# ── WhatsApp (Evolution API v2) ────────────────────────────────────────────
# DAX_WHATSAPP__EVOLUTION_API_KEY=your-api-key
# Shared secret the webhook requires in the `apikey` header (reject otherwise).
# DAX_WHATSAPP__WEBHOOK_SECRET=your-webhook-secret
